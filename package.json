    "postinstall": "prisma generate",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "preview": "next build && next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
